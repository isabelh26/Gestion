apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend-deployment
  namespace: gestiona
spec:
  replicas: 2
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      containers:
      - name: backend
        image: gestiona/backend-gestion:latest 
        imagePullPolicy: Never
        ports:
        - containerPort: 8080
        env:
        - name: SPRING_DATASOURCE_URL
          value: jdbc:postgresql://postgres-sql15-service:5432/gestion
        - name: SPRING_DATASOURCE_USERNAME
          value: admin
        - name: SPRING_DATASOURCE_PASSWORD
          value: admin01
---
apiVersion: v1
kind: Service
metadata:
  name: backend-service
  namespace: gestiona
spec:
  type: NodePort #ClusterIP
  selector:
    app: backend
  ports:
    - port: 8080
      targetPort: 8080
      nodePort: 30002  